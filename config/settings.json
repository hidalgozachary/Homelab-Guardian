{
  "guardian_name": "Homelab Guardian",
  "version": "0.6.5",
  "warning_thresholds": {
    "cpu_percent": 80,
    "memory_percent": 80,
    "disk_percent": 85
  },
  "reports": {
    "directory": "sample-output"
  },
  "logging": {
    "directory": "logs",
    "level": "INFO"
  },
  "network": {
    "timeout_seconds": 5,
    "internet_url": "https://www.google.com",
    "dns_hostname": "cloudflare.com"
  },
  "process_monitoring": {
    "enabled": true,
    "process_limit": 5,
    "sample_seconds": 1
  },
  "notifications": {
    "email_enabled": true,
    "discord_enabled": false,
    "send_healthy_reports": true
  }
}